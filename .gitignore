# Rust build artifacts
/target
**/*.rs.bk

# Cargo.lock IS committed (reproducibility / pinned versions — SPEC §2.1.7).

# macOS
.DS_Store

# Large / fetched-once data caches (SPEC §5)
/data/genomes/
/data/ontology/*
!/data/ontology/.gitkeep
/data/runs/*
!/data/runs/.gitkeep

# Criterion bench raw output (baselines are recorded in docs, not committed)
/target/criterion

# Godot (built LAST — Stage 4)
/godot/.godot/
/godot/.import/

# Python glue
__pycache__/
*.pyc
.venv/

# Godot 4.x per-script UID cache (we resolve scripts by preload path, not UID)
*.uid
# Generated res:// mirror of the canonical repo-root data/species/ (ADR-017): staged by run.sh / CI before
# launch+export, byte-checked against data/species/ by the gate. Never hand-edit or commit (single source of
# truth stays at repo-root data/species/).
/godot/data/
# Detached godot-sim cdylib build output
/crates/godot-sim/target/
# CI-staged Godot export artifacts (release.yml writes these into godot/ transiently)
/godot/libgodot_sim.*
/godot/godot_sim.dll
/godot/gene_sim.gdextension
/build/
/dist/
/debroot/

# Claude Code session runtime (scheduled-task lock/state) — not project source
/.claude/scheduled_tasks.lock
/.claude/scheduled_tasks.json

# Local run config (sourced by run.sh; ship run.config.example)
/run.config
