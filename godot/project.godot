; gene-sim — thin 2D UI (Godot 4.7). Built LAST (SPEC build order).
; INVARIANT #2: this project READS sim snapshots only. NO genotype→phenotype / biology logic in GDScript. Ever.
; config_version 5 == Godot 4.x.

config_version=5

[application]

config/name="gene-sim"
config/description="Thin 2D renderer for the gene-sim headless core. Reads snapshots; computes no biology (invariant #2)."
run/main_scene="res://Main.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
